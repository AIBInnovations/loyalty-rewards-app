{% comment %}
  Wishlist - App Block
  Renders the customer's full wishlist (product-level saves + cart-side
  saves shown together). Place on /pages/wishlist or the cart page.
{% endcomment %}

<section
  class="wl-page"
  data-wl-page
  data-shop-domain="{{ shop.permanent_domain }}"
  data-customer-id="{{ customer.id }}"
  data-cart-currency="{{ shop.currency }}"
  style="
    --wl-color: {{ block.settings.icon_color }};
    --wl-active: {{ block.settings.active_color }};
    --wl-cta: {{ block.settings.cta_color }};
  "
>
  <div class="wl-page-inner">
    <div class="wl-section" data-wl-section="all">
      <h2 class="wl-section-title">{{ block.settings.title }}</h2>
      <div class="wl-list" data-wl-list="all"></div>
      <p class="wl-empty" data-wl-empty="all" style="display:none;">
        {{ block.settings.empty_message }}
      </p>
    </div>
  </div>
</section>

{{ 'wishlist.css' | asset_url | stylesheet_tag }}
<script src="{{ 'wishlist.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Wishlist Page",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "My Wishlist"
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Empty message",
      "default": "Your wishlist is empty. Tap the heart on any product to save it."
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#222222"
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "Active color",
      "default": "#e63946"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "CTA color",
      "default": "#1a1a1a"
    }
  ]
}
{% endschema %}
