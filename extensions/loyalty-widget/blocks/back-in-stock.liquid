{% comment %}
  Back-in-Stock Alerts - App Block (product pages)
  Shows "Notify Me" form when a product variant is out of stock.
{% endcomment %}

{% assign selected_variant = product.selected_or_first_available_variant %}
{% if selected_variant.available == false %}
  <div
    class="bis-container"
    id="bis-notify-form"
    data-product-id="{{ product.id }}"
    data-product-title="{{ product.title | escape }}"
    data-variant-id="{{ selected_variant.id }}"
    data-variant-title="{{ selected_variant.title | escape }}"
    data-shop-domain="{{ shop.permanent_domain }}"
    style="--bis-color: {{ block.settings.button_color }};"
  >
    <div class="bis-inner">
      <p class="bis-heading">{{ block.settings.heading }}</p>
      <p class="bis-subtext">{{ block.settings.subtext }}</p>
      <div class="bis-form">
        <input
          type="email"
          class="bis-email"
          placeholder="{{ block.settings.placeholder }}"
          required
          aria-label="Email for back in stock notification"
        />
        <button type="button" class="bis-btn" data-action="bis-submit">
          {{ block.settings.button_text }}
        </button>
      </div>
      <p class="bis-success" style="display:none;">{{ block.settings.success_message }}</p>
      <p class="bis-error" style="display:none;"></p>
    </div>
  </div>

  {{ 'back-in-stock.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'back-in-stock.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Back in Stock Alert",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Sold Out? Get Notified!"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Sub Text",
      "default": "Enter your email and we'll notify you when this product is back."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email Placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Notify Me"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "✅ You're on the list! We'll email you when it's back."
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#5C6AC4"
    }
  ]
}
{% endschema %}
