{% comment %}
  WhatsApp Chat Button - App Embed Block
  Floating button that opens WhatsApp with pre-filled message.
  No backend needed - all config in Theme Editor.
{% endcomment %}

{%- comment -%}WhatsApp Button embed rendered. phone_number blank? {%- if block.settings.phone_number == blank -%}YES{%- else -%}NO{%- endif -%}{%- endcomment -%}
{% if block.settings.phone_number != blank %}
  {% assign wa_number = block.settings.phone_number | remove: '+' | remove: ' ' | remove: '-' %}
  {% assign wa_message = block.settings.prefilled_message | url_encode %}
  {% assign wa_side = block.settings.position | default: 'bottom-left' %}

  <a
    href="https://wa.me/{{ wa_number }}{% if wa_message != blank %}?text={{ wa_message }}{% endif %}"
    target="_blank"
    rel="noopener noreferrer"
    class="wa-float wa-{{ wa_side }}"
    data-wa-float
    style="
      --wa-color: {{ block.settings.button_color }};
      --wa-bottom: {{ block.settings.bottom_offset }}px;
      position: fixed !important;
      {% if wa_side == 'bottom-right' %}right: 20px !important; left: auto !important;{% else %}left: 20px !important; right: auto !important;{% endif %}
      bottom: {{ block.settings.bottom_offset }}px !important;
      z-index: 2147483000 !important;
      width: 56px !important;
      height: 56px !important;
      border-radius: 50% !important;
      background: {{ block.settings.button_color }} !important;
      display: flex !important;
      align-items: center !important;
      justify-content: center !important;
      color: #fff !important;
      text-decoration: none !important;
      box-shadow: 0 4px 12px rgba(37, 211, 102, 0.4) !important;
      visibility: visible !important;
      opacity: 1 !important;
      pointer-events: auto !important;
    "
    aria-label="Chat on WhatsApp"
    title="{{ block.settings.tooltip_text }}"
  >
    <svg class="wa-icon" viewBox="0 0 32 32" fill="none" style="width:30px !important;height:30px !important;display:block !important;">
      <path d="M16.004 2.003C8.27 2.003 2 8.27 2 15.997c0 2.478.648 4.9 1.878 7.03L2 30l7.188-1.853A13.94 13.94 0 0016.004 30C23.73 30 30 23.724 30 15.997 30 8.27 23.73 2.003 16.004 2.003zm0 25.498a11.47 11.47 0 01-5.862-1.608l-.42-.249-4.354 1.12 1.16-4.226-.274-.435a11.4 11.4 0 01-1.756-6.106c0-6.363 5.183-11.543 11.55-11.543 6.364 0 11.548 5.18 11.548 11.543-.003 6.366-5.186 11.504-11.592 11.504z" fill="currentColor"/>
      <path d="M23.063 19.076c-.376-.188-2.228-1.098-2.573-1.224-.346-.125-.598-.188-.85.188-.25.376-.973 1.224-1.194 1.474-.219.25-.44.282-.816.094-.376-.188-1.587-.585-3.023-1.864-1.118-.996-1.873-2.226-2.092-2.602-.22-.376-.024-.58.165-.767.169-.168.376-.44.564-.66.188-.22.25-.376.376-.626.125-.25.063-.47-.032-.658-.094-.188-.85-2.048-1.164-2.804-.307-.736-.619-.636-.85-.648-.22-.01-.47-.012-.72-.012-.25 0-.658.094-.1.47-.345.376-1.318 1.286-1.318 3.138 0 1.852 1.35 3.641 1.538 3.892.188.25 2.655 4.053 6.432 5.683.899.388 1.6.62 2.147.793.902.287 1.723.246 2.372.15.723-.108 2.228-.91 2.543-1.79.314-.878.314-1.63.22-1.79-.094-.156-.346-.25-.722-.438z" fill="currentColor"/>
    </svg>
    {% if block.settings.show_tooltip %}
      <span class="wa-tooltip">{{ block.settings.tooltip_text }}</span>
    {% endif %}
  </a>

  {{ 'whatsapp-button.css' | asset_url | stylesheet_tag }}
{% endif %}

{% schema %}
{
  "name": "WhatsApp Button",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "phone_number",
      "label": "WhatsApp Number",
      "info": "Include country code. Example: +919876543210",
      "default": "+919876543210"
    },
    {
      "type": "text",
      "id": "prefilled_message",
      "label": "Pre-filled Message",
      "default": "Hi! I have a question about your products."
    },
    {
      "type": "select",
      "id": "position",
      "label": "Button Position",
      "options": [
        { "value": "bottom-left", "label": "Bottom Left" },
        { "value": "bottom-right", "label": "Bottom Right" }
      ],
      "default": "bottom-left"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button Color",
      "default": "#25D366"
    },
    {
      "type": "text",
      "id": "tooltip_text",
      "label": "Tooltip Text",
      "default": "Chat with us!"
    },
    {
      "type": "checkbox",
      "id": "show_tooltip",
      "label": "Show Tooltip",
      "default": true
    },
    {
      "type": "range",
      "id": "bottom_offset",
      "label": "Bottom Offset",
      "info": "Adjust to avoid overlap with other widgets",
      "min": 16,
      "max": 120,
      "step": 4,
      "default": 24,
      "unit": "px"
    }
  ]
}
{% endschema %}
