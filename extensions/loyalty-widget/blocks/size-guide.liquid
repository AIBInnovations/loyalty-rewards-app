{% comment %}
  Size Guide - App Embed Block (product pages only)
  All content (trigger label, chart rows, colors, enable/disable) is
  managed in the app admin at /app/size-guide-settings. This embed
  renders a hidden shell + modal on product pages and the JS injects
  the trigger button near the variant/size selector.
{% endcomment %}

{% if template.name == 'product' %}
<div
  class="sg-container"
  id="sg-embed"
  data-sg-root
  data-shop-domain="{{ shop.permanent_domain }}"
  data-app-proxy-url="/apps/loyalty"
  data-shop-name="{{ shop.name | escape }}"
  data-anchor="{{ block.settings.anchor }}"
>
  <template data-sg-trigger-tpl>
    <button type="button" class="sg-trigger" data-sg-open aria-haspopup="dialog">
      <svg class="sg-trigger-icon" data-sg-icon viewBox="0 0 24 24" fill="none" aria-hidden="true" hidden>
        <path d="M2 9h20v6H2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        <path d="M6 9v3M10 9v4M14 9v3M18 9v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <span data-sg-label>Size Chart</span>
    </button>
  </template>

  <div class="sg-overlay" data-sg-overlay role="dialog" aria-modal="true" aria-labelledby="sg-title" hidden>
    <div class="sg-modal" role="document">
      <div class="sg-header">
        <span class="sg-logo-text" data-sg-shop-name>{{ shop.name }}</span>
        <h2 class="sg-header-title" id="sg-title" data-sg-modal-title>Size Charts</h2>
        <button type="button" class="sg-close" data-sg-close aria-label="Close size chart">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" width="22" height="22">
            <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <div class="sg-body">
        <h3 class="sg-chart-title" data-sg-chart-title></h3>

        <div class="sg-unit-tabs" role="tablist">
          <button type="button" class="sg-unit sg-unit-active" data-sg-unit="cm" role="tab" aria-selected="true">CM</button>
          <span class="sg-unit-sep">|</span>
          <button type="button" class="sg-unit" data-sg-unit="in" role="tab" aria-selected="false">INCHES</button>
        </div>

        <div class="sg-table-wrap" data-sg-table-wrap>
          <table class="sg-table" data-sg-table>
            <thead data-sg-thead></thead>
            <tbody data-sg-tbody></tbody>
          </table>
        </div>

        <p class="sg-note" data-sg-note hidden></p>
      </div>
    </div>
  </div>
</div>

{{ 'size-guide.css' | asset_url | stylesheet_tag }}
<script src="{{ 'size-guide.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "Size Guide",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "All chart content and colors are managed in the app admin under 'Size Guide' (enable/disable, edit rows, etc). This embed only controls where the trigger button is placed on the product page."
    },
    {
      "type": "select",
      "id": "anchor",
      "label": "Trigger Placement",
      "options": [
        { "value": "above-variants", "label": "Above size/variant selector" },
        { "value": "below-variants", "label": "Below size/variant selector" },
        { "value": "above-atc", "label": "Above Add to Cart" },
        { "value": "below-atc", "label": "Below Add to Cart" }
      ],
      "default": "above-variants"
    }
  ]
}
{% endschema %}
