{% comment %}
  Trust Badges - App Embed Block (body target = appears in App Embeds)
  Fetches badge config from app proxy and injects below the Add to Cart button
  on product pages. Falls back to block settings if proxy is unavailable.
{% endcomment %}

{% if template.name == 'product' %}

{% assign tb_layout = block.settings.layout %}
{% assign tb_icon_size = block.settings.icon_size %}
{% assign tb_text_color = block.settings.text_color %}
{% assign tb_icon_color = block.settings.icon_color %}
{% assign tb_bg = block.settings.background_color %}

{% capture tb_svg_cod %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01M6 12h.01M18 12h.01"/><path d="M2 10h20"/></svg>
{% endcapture %}

{% capture tb_svg_lock %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
{% endcapture %}

{% capture tb_svg_shield %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
{% endcapture %}

{% capture tb_svg_card %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
{% endcapture %}

{% capture tb_svg_truck %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
{% endcapture %}

{% capture tb_svg_returns %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
{% endcapture %}

{% capture tb_svg_check %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
{% endcapture %}

{% capture tb_svg_star %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
{% endcapture %}

{% capture tb_svg_package %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
{% endcapture %}

{% capture tb_svg_gift %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
{% endcapture %}

{% capture tb_svg_clock %}
<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
{% endcapture %}

<div
  id="tb-embed-{{ block.id }}"
  class="tb-container"
  style="
    --tb-icon-size: {{ tb_icon_size }}px;
    --tb-text-color: {{ tb_text_color }};
    --tb-icon-color: {{ tb_icon_color }};
    --tb-bg: {{ tb_bg }};
    display: none;
  "
>
  <div id="tb-static-{{ block.id }}" class="tb-grid tb-layout-{{ tb_layout }}">
    {% assign tb_badges = 'badge_1,badge_2,badge_3,badge_4,badge_5,badge_6' | split: ',' %}
    {% for badge_key in tb_badges %}
      {% assign tb_icon_key = badge_key | append: '_icon' %}
      {% assign tb_text_key = badge_key | append: '_text' %}
      {% assign tb_icon_val = block.settings[tb_icon_key] %}
      {% assign tb_text_val = block.settings[tb_text_key] %}
      {% if tb_text_val != blank %}
        <div class="tb-badge">
          <span class="tb-icon">
            {% case tb_icon_val %}
              {% when 'cod' %}{{ tb_svg_cod }}
              {% when 'lock' %}{{ tb_svg_lock }}
              {% when 'shield' %}{{ tb_svg_shield }}
              {% when 'card' %}{{ tb_svg_card }}
              {% when 'truck' %}{{ tb_svg_truck }}
              {% when 'returns' %}{{ tb_svg_returns }}
              {% when 'check' %}{{ tb_svg_check }}
              {% when 'star' %}{{ tb_svg_star }}
              {% when 'package' %}{{ tb_svg_package }}
              {% when 'gift' %}{{ tb_svg_gift }}
              {% when 'clock' %}{{ tb_svg_clock }}
            {% endcase %}
          </span>
          <span class="tb-text">{{ tb_text_val }}</span>
        </div>
      {% endif %}
    {% endfor %}
  </div>
  <div id="tb-dynamic-{{ block.id }}" class="tb-grid" style="display:none;"></div>
</div>

{{ 'trust-badges.css' | asset_url | stylesheet_tag }}

<script>
(function() {
  var SVGS = {
    cod:     '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M12 12h.01M6 12h.01M18 12h.01"/><path d="M2 10h20"/></svg>',
    lock:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>',
    shield:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>',
    card:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>',
    truck:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
    returns: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>',
    check:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>',
    star:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>',
    package: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="16.5" y1="9.4" x2="7.5" y2="4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>',
    gift:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>',
    clock:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  };

  function buildBadgeHtml(badges, layout) {
    var html = "";
    badges.forEach(function(b) {
      if (!b.text) return;
      var svg = b.icon && SVGS[b.icon] ? SVGS[b.icon] : "";
      html += '<div class="tb-badge">' +
        '<span class="tb-icon">' + svg + '</span>' +
        '<span class="tb-text">' + b.text + '</span>' +
        '</div>';
    });
    return html;
  }

  function injectBadges(data) {
    var embed = document.getElementById("tb-embed-{{ block.id }}");
    var staticEl = document.getElementById("tb-static-{{ block.id }}");
    var dynamicEl = document.getElementById("tb-dynamic-{{ block.id }}");
    if (!embed) return;

    embed.style.display = "";

    if (data && data.enabled && data.badges && data.badges.length) {
      dynamicEl.className = "tb-grid tb-layout-" + (data.layout || "inline");
      dynamicEl.innerHTML = buildBadgeHtml(data.badges, data.layout);
      staticEl.style.display = "none";
      dynamicEl.style.display = "";
    }
    // else keep staticEl visible (fallback from block settings)

    // Auto-position: insert after ATC button or product form
    var anchor =
      document.querySelector('form[action*="/cart/add"] [type="submit"]') ||
      document.querySelector('[name="add"]') ||
      document.querySelector('form[action*="/cart/add"]') ||
      document.querySelector('.product-form') ||
      document.querySelector('.product__info-container');

    if (anchor && anchor.parentNode) {
      anchor.parentNode.insertBefore(embed, anchor.nextSibling);
    }
  }

  fetch("/apps/loyalty/trust-badges")
    .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
    .then(function(data) {
      if (data.enabled === false) return;
      injectBadges(data);
    })
    .catch(function() {
      injectBadges(null);
    });
})();
</script>

{% endif %}

