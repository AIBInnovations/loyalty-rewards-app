{% comment %}
  Countdown Timer - App Embed Block
  Supports fixed deadline and evergreen (per-session) timers.
  Display modes: announcement bar, product page, or both.
  Works for ALL visitors.
{% endcomment %}

<div
  id="countdown-timer-app"
  data-shop-domain="{{ shop.permanent_domain }}"
  data-template="{{ template.name }}"
  data-product-id="{{ product.id | default: '' }}"
  data-product-tags="{{ product.tags | join: ',' | default: '' }}"
  data-has-sale="{% if product.compare_at_price_max > product.price_max %}true{% else %}false{% endif %}"
  data-product-title="{{ product.title | escape | default: '' }}"
  data-bar-bg="{{ block.settings.bar_background_color }}"
  data-bar-text="{{ block.settings.bar_text_color }}"
  data-digit-color="{{ block.settings.timer_digit_color }}"
  style="display: none;"
></div>

{{ 'countdown-timer.css' | asset_url | stylesheet_tag }}

<script>
(function () {
  var colors = null;

  function applyColors() {
    if (!colors) return;
    document.querySelectorAll('[id="ct-announcement-bar"]').forEach(function (bar) {
      if (colors.bg) bar.style.setProperty('background', colors.bg, 'important');
      if (colors.text) bar.style.setProperty('color', colors.text, 'important');
      bar.querySelectorAll('.ct-digit-box, .ct-separator').forEach(function (el) {
        if (colors.digit) el.style.setProperty('color', colors.digit, 'important');
      });
      bar.querySelectorAll('.ct-dismiss').forEach(function (el) {
        if (colors.text) el.style.setProperty('color', colors.text, 'important');
      });
    });
    document.querySelectorAll('[id="ct-product-timer"]').forEach(function (el) {
      if (colors.digit) el.style.setProperty('border-left-color', colors.digit, 'important');
      el.querySelectorAll('.ct-digit-box, .ct-separator').forEach(function (d) {
        if (colors.digit) d.style.setProperty('color', colors.digit, 'important');
      });
      var dot = el.querySelector('.ct-pulse-dot');
      if (dot && colors.digit) dot.style.setProperty('background', colors.digit, 'important');
    });
  }

  fetch('/apps/loyalty/timer-settings')
    .then(function (r) { return r.json(); })
    .then(function (d) {
      if (!d || !d.enabled) return;
      colors = { bg: d.barBackgroundColor, text: d.barTextColor, digit: d.timerDigitColor };
      applyColors();
      new MutationObserver(applyColors).observe(document.body, { childList: true, subtree: true });
    })
    .catch(function () {});
})();
</script>

<script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Countdown Timer",
  "target": "body",
  "settings": [
    {
      "type": "color",
      "id": "bar_background_color",
      "label": "Bar Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "bar_text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "timer_digit_color",
      "label": "Timer Digit Color",
      "default": "#ff4444"
    }
  ]
}
{% endschema %}
