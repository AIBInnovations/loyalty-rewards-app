{% comment %}
  FAQ Accordion + FAQPage JSON-LD - App Block
  Server-rendered accordion. Two content sources:
    1. "blocks"    - up to 12 Q&A pairs configured in theme customizer
    2. "metafield" - references a faq_group metaobject via product/collection/page metafield
                     (expected handle: custom.faq_group with entries -> faq_entry)
  JSON-LD is emitted from the final visible items only, so schema always matches
  on-page content.
{% endcomment %}

{%- liquid
  assign source_mode = block.settings.source_mode
  assign max_items = block.settings.max_items | default: 0

  assign faq_entries = nil
  if source_mode == 'metafield'
    case template.name
      when 'product'
        assign faq_group = product.metafields.custom.faq_group.value
      when 'collection'
        assign faq_group = collection.metafields.custom.faq_group.value
      when 'page'
        assign faq_group = page.metafields.custom.faq_group.value
    endcase
    if faq_group and faq_group.entries
      assign faq_entries = faq_group.entries.value
    endif
  endif

  assign visible_count = 0
  if source_mode == 'metafield'
    if faq_entries
      for entry in faq_entries
        assign eq = entry.question | default: '' | strip_html | strip
        assign ea = entry.answer | default: '' | strip_html | strip
        if eq != blank and ea != blank
          assign visible_count = visible_count | plus: 1
        endif
      endfor
    endif
  else
    for i in (1..12)
      assign q_key = 'question_' | append: i
      assign a_key = 'answer_' | append: i
      assign bq = block.settings[q_key] | default: '' | strip
      assign ba = block.settings[a_key] | default: '' | strip
      if bq != blank and ba != blank
        assign visible_count = visible_count | plus: 1
      endif
    endfor
  endif
-%}

{%- if visible_count > 0 -%}
<section
  class="faq-accordion faq-style-{{ block.settings.icon_style }}"
  id="faq-{{ block.id }}"
  data-faq-root
  data-allow-multiple="{{ block.settings.allow_multiple }}"
  data-first-open="{{ block.settings.first_open }}"
  aria-labelledby="faq-heading-{{ block.id }}"
  style="
    --faq-bg: {{ block.settings.background_color }};
    --faq-text: {{ block.settings.text_color }};
    --faq-accent: {{ block.settings.accent_color }};
    --faq-border: {{ block.settings.border_color }};
    --faq-radius: {{ block.settings.border_radius }}px;
    --faq-gap: {{ block.settings.item_gap }}px;
    --faq-max-width: {{ block.settings.max_width }}px;
  "
>
  <div class="faq-inner">
    {%- if block.settings.heading != blank -%}
      <h2 class="faq-heading" id="faq-heading-{{ block.id }}">{{ block.settings.heading }}</h2>
    {%- endif -%}
    {%- if block.settings.subheading != blank -%}
      <p class="faq-subheading">{{ block.settings.subheading }}</p>
    {%- endif -%}

    <ul class="faq-list" role="list">
      {%- assign idx = 0 -%}

      {%- if source_mode == 'metafield' -%}
        {%- for entry in faq_entries -%}
          {%- assign question = entry.question | default: '' | strip_html | strip -%}
          {%- assign answer_html = entry.answer -%}
          {%- assign answer_plain = entry.answer | default: '' | strip_html | strip -%}
          {%- if question != blank and answer_plain != blank -%}
            {%- assign idx = idx | plus: 1 -%}
            {%- if max_items > 0 and idx > max_items -%}{%- break -%}{%- endif -%}
            {%- assign is_open = false -%}
            {%- if block.settings.first_open and idx == 1 -%}{%- assign is_open = true -%}{%- endif -%}
            {%- assign panel_id = 'faq-panel-' | append: block.id | append: '-' | append: idx -%}
            {%- assign trigger_id = 'faq-trigger-' | append: block.id | append: '-' | append: idx -%}
            <li class="faq-item{% if is_open %} is-open{% endif %}" data-faq-item>
              <h3 class="faq-question-wrap">
                <button
                  type="button"
                  class="faq-question"
                  id="{{ trigger_id }}"
                  aria-expanded="{{ is_open }}"
                  aria-controls="{{ panel_id }}"
                  data-faq-trigger
                >
                  <span class="faq-q-text">{{ question }}</span>
                  <span class="faq-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
              </h3>
              <div
                class="faq-panel"
                id="{{ panel_id }}"
                role="region"
                aria-labelledby="{{ trigger_id }}"
                {% unless is_open %}hidden{% endunless %}
              >
                <div class="faq-answer">{{ answer_html }}</div>
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..12) -%}
          {%- assign q_key = 'question_' | append: i -%}
          {%- assign a_key = 'answer_' | append: i -%}
          {%- assign question = block.settings[q_key] | default: '' | strip -%}
          {%- assign answer_raw = block.settings[a_key] | default: '' -%}
          {%- assign answer_plain = answer_raw | strip -%}
          {%- if question != blank and answer_plain != blank -%}
            {%- assign idx = idx | plus: 1 -%}
            {%- if max_items > 0 and idx > max_items -%}{%- break -%}{%- endif -%}
            {%- assign is_open = false -%}
            {%- if block.settings.first_open and idx == 1 -%}{%- assign is_open = true -%}{%- endif -%}
            {%- assign panel_id = 'faq-panel-' | append: block.id | append: '-' | append: idx -%}
            {%- assign trigger_id = 'faq-trigger-' | append: block.id | append: '-' | append: idx -%}
            <li class="faq-item{% if is_open %} is-open{% endif %}" data-faq-item>
              <h3 class="faq-question-wrap">
                <button
                  type="button"
                  class="faq-question"
                  id="{{ trigger_id }}"
                  aria-expanded="{{ is_open }}"
                  aria-controls="{{ panel_id }}"
                  data-faq-trigger
                >
                  <span class="faq-q-text">{{ question }}</span>
                  <span class="faq-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none">
                      <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </span>
                </button>
              </h3>
              <div
                class="faq-panel"
                id="{{ panel_id }}"
                role="region"
                aria-labelledby="{{ trigger_id }}"
                {% unless is_open %}hidden{% endunless %}
              >
                <div class="faq-answer">{{ answer_raw | newline_to_br }}</div>
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>

  {%- if block.settings.enable_schema -%}
    {%- capture faq_schema -%}
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {%- assign sidx = 0 -%}
          {%- if source_mode == 'metafield' -%}
            {%- for entry in faq_entries -%}
              {%- assign s_q = entry.question | default: '' | strip_html | strip -%}
              {%- assign s_a = entry.answer | default: '' | strip_html | strip | truncate: 1000 -%}
              {%- if s_q != blank and s_a != blank -%}
                {%- assign sidx = sidx | plus: 1 -%}
                {%- if max_items > 0 and sidx > max_items -%}{%- break -%}{%- endif -%}
                {%- if sidx > 1 -%},{%- endif -%}
                {
                  "@type": "Question",
                  "name": {{ s_q | json }},
                  "acceptedAnswer": {
                    "@type": "Answer",
                    "text": {{ s_a | json }}
                  }
                }
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..12) -%}
              {%- assign q_key = 'question_' | append: i -%}
              {%- assign a_key = 'answer_' | append: i -%}
              {%- assign s_q = block.settings[q_key] | default: '' | strip -%}
              {%- assign s_a = block.settings[a_key] | default: '' | strip_html | strip | truncate: 1000 -%}
              {%- if s_q != blank and s_a != blank -%}
                {%- assign sidx = sidx | plus: 1 -%}
                {%- if max_items > 0 and sidx > max_items -%}{%- break -%}{%- endif -%}
                {%- if sidx > 1 -%},{%- endif -%}
                {
                  "@type": "Question",
                  "name": {{ s_q | json }},
                  "acceptedAnswer": {
                    "@type": "Answer",
                    "text": {{ s_a | json }}
                  }
                }
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        ]
      }
    {%- endcapture -%}
    <script type="application/ld+json">{{ faq_schema | strip_newlines }}</script>
  {%- endif -%}
</section>

{{ 'faq-accordion.css' | asset_url | stylesheet_tag }}
<script src="{{ 'faq-accordion.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "FAQ Accordion",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": ""
    },
    {
      "type": "select",
      "id": "source_mode",
      "label": "FAQ Source",
      "options": [
        { "value": "blocks", "label": "Theme editor (use Q&A fields below)" },
        { "value": "metafield", "label": "Metaobject reference (custom.faq_group)" }
      ],
      "default": "blocks",
      "info": "Metaobject mode expects a 'faq_group' metaobject with an 'entries' list of 'faq_entry' (question, answer, status)."
    },
    {
      "type": "header",
      "content": "Behavior"
    },
    {
      "type": "checkbox",
      "id": "allow_multiple",
      "label": "Allow multiple items open at once",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "first_open",
      "label": "Open first item by default",
      "default": true
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Max items to display (0 = no limit)",
      "min": 0,
      "max": 12,
      "step": 1,
      "default": 0
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Icon Style",
      "options": [
        { "value": "chevron", "label": "Chevron" },
        { "value": "plus", "label": "Plus / Minus" }
      ],
      "default": "chevron"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width",
      "min": 480,
      "max": 1200,
      "step": 20,
      "default": 880,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Space Between Items",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "default": 8,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#5C6AC4"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e5e7eb"
    },
    {
      "type": "header",
      "content": "SEO / Structured Data"
    },
    {
      "type": "checkbox",
      "id": "enable_schema",
      "label": "Emit FAQPage JSON-LD",
      "default": true,
      "info": "Enable on pages where the FAQ is page-specific. Avoid duplicating identical schema across the entire catalog."
    },
    {
      "type": "header",
      "content": "Q&A Pairs (Theme editor mode)"
    },
    { "type": "text", "id": "question_1", "label": "Q1", "default": "What is your return policy?" },
    { "type": "textarea", "id": "answer_1", "label": "A1", "default": "We accept returns within 30 days of delivery for unused items in original packaging." },
    { "type": "text", "id": "question_2", "label": "Q2", "default": "How long does shipping take?" },
    { "type": "textarea", "id": "answer_2", "label": "A2", "default": "Standard shipping takes 3-5 business days. Express options are available at checkout." },
    { "type": "text", "id": "question_3", "label": "Q3", "default": "Do you ship internationally?" },
    { "type": "textarea", "id": "answer_3", "label": "A3", "default": "Yes, we ship to most countries. Rates and times are calculated at checkout." },
    { "type": "text", "id": "question_4", "label": "Q4" },
    { "type": "textarea", "id": "answer_4", "label": "A4" },
    { "type": "text", "id": "question_5", "label": "Q5" },
    { "type": "textarea", "id": "answer_5", "label": "A5" },
    { "type": "text", "id": "question_6", "label": "Q6" },
    { "type": "textarea", "id": "answer_6", "label": "A6" },
    { "type": "text", "id": "question_7", "label": "Q7" },
    { "type": "textarea", "id": "answer_7", "label": "A7" },
    { "type": "text", "id": "question_8", "label": "Q8" },
    { "type": "textarea", "id": "answer_8", "label": "A8" },
    { "type": "text", "id": "question_9", "label": "Q9" },
    { "type": "textarea", "id": "answer_9", "label": "A9" },
    { "type": "text", "id": "question_10", "label": "Q10" },
    { "type": "textarea", "id": "answer_10", "label": "A10" },
    { "type": "text", "id": "question_11", "label": "Q11" },
    { "type": "textarea", "id": "answer_11", "label": "A11" },
    { "type": "text", "id": "question_12", "label": "Q12" },
    { "type": "textarea", "id": "answer_12", "label": "A12" }
  ]
}
{% endschema %}
