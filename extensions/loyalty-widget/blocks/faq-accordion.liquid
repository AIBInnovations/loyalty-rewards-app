{% comment %}
  FAQ Accordion - App Embed
  All content (questions, answers, enable/disable, colors, placement) is
  managed in the app admin under "FAQ Accordion". This embed is a tiny
  bootstrap that fetches config from /apps/loyalty/faq-settings and
  renders the accordion + FAQPage JSON-LD client-side.
{% endcomment %}

<div
  class="faq-container"
  id="faq-embed"
  data-faq-root
  data-shop-domain="{{ shop.permanent_domain }}"
  data-app-proxy-url="/apps/loyalty"
  data-template-name="{{ template.name }}"
></div>

{{ 'faq-accordion.css' | asset_url | stylesheet_tag }}
<script src="{{ 'faq-accordion.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "FAQ Accordion",
  "target": "body",
  "settings": [
    {
      "type": "paragraph",
      "content": "All FAQ content (questions, answers, enable/disable, placement, colors) is managed in the app admin under 'FAQ Accordion'. This embed only loads the storefront renderer."
    }
  ]
}
{% endschema %}
