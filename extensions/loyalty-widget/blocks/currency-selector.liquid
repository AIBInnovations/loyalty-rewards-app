{% comment %}
  Currency Selector - App Embed
  - Custom dropdown: Flag + "Currency Name (CODE)" format
  - JS-based price conversion using live exchange rates
  - Persists selection across pages via localStorage
{% endcomment %}

{% assign cs_enabled = shop.metafields.loyalty_widget.currency_selector_enabled | default: true %}
{% assign custom_currencies = shop.metafields.loyalty_widget.currencies %}
{% assign base_currency = shop.currency %}
{% assign money_format = shop.money_format %}

{% unless cs_enabled == false %}

  {% comment %} Data container — JS reads currencies from here {% endcomment %}
  <div id="loy-cs-data-{{ block.id }}" style="display:none;"
    data-base="{{ base_currency }}"
    data-money-format="{{ money_format | escape }}"
    data-current-country="{{ localization.country.iso_code }}"
  >
    {% if custom_currencies != blank %}
      {% comment %} Admin-configured currencies from metafield {% endcomment %}
      {% for cur in custom_currencies %}
        <span
          data-country="{{ cur.countryCode }}"
          data-code="{{ cur.currencyCode }}"
          data-label="{{ cur.label | escape }}"
          data-flag="{{ cur.flag }}"
          data-symbol="{{ cur.symbol | escape }}"
        ></span>
      {% endfor %}
    {% else %}
      {% comment %} Fallback: hardcoded popular currencies so widget always renders {% endcomment %}
      <span data-country="IN" data-code="INR" data-label="Indian Rupee"       data-flag="🇮🇳" data-symbol="₹"></span>
      <span data-country="US" data-code="USD" data-label="US Dollar"          data-flag="🇺🇸" data-symbol="$"></span>
      <span data-country="GB" data-code="GBP" data-label="British Pound"      data-flag="🇬🇧" data-symbol="£"></span>
      <span data-country="DE" data-code="EUR" data-label="Euro"               data-flag="🇪🇺" data-symbol="€"></span>
      <span data-country="AU" data-code="AUD" data-label="Australian Dollar"  data-flag="🇦🇺" data-symbol="A$"></span>
      <span data-country="AE" data-code="AED" data-label="UAE Dirham"         data-flag="🇦🇪" data-symbol="د.إ"></span>
      <span data-country="SA" data-code="SAR" data-label="Saudi Riyal"        data-flag="🇸🇦" data-symbol="﷼"></span>
      <span data-country="CA" data-code="CAD" data-label="Canadian Dollar"    data-flag="🇨🇦" data-symbol="CA$"></span>
      <span data-country="SG" data-code="SGD" data-label="Singapore Dollar"   data-flag="🇸🇬" data-symbol="S$"></span>
      <span data-country="JP" data-code="JPY" data-label="Japanese Yen"       data-flag="🇯🇵" data-symbol="¥"></span>
    {% endif %}
  </div>

  <style>
    #loy-cs-bar-{{ block.id }} {
      width: 100%;
      display: flex;
      align-items: center;
      padding: 6px {{ block.settings.bar_padding_x }}px;
      background: {{ block.settings.bar_background }};
      border-bottom: 1px solid {{ block.settings.border_color }};
      box-sizing: border-box;
      position: sticky;
      top: 0;
      z-index: 10000;
    }
    .loy-cs-wrap {
      position: relative;
      display: inline-flex;
      align-items: center;
      font-family: inherit;
      font-size: 13px;
    }
    .loy-cs-trigger {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: {{ block.settings.background_color }};
      color: {{ block.settings.text_color }};
      border: 1px solid {{ block.settings.border_color }};
      border-radius: {{ block.settings.border_radius }}px;
      padding: 6px 10px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      min-width: 160px;
      text-align: left;
      line-height: 1.4;
      white-space: nowrap;
    }
    .loy-cs-trigger:hover { background: {{ block.settings.hover_color }}; }
    .loy-cs-flag  { font-size: 16px; line-height: 1; flex-shrink: 0; }
    .loy-cs-label { flex: 1; }
    .loy-cs-chevron {
      color: #999; flex-shrink: 0;
      display: flex; align-items: center;
      transition: transform 0.2s;
    }
    .loy-cs-trigger[aria-expanded="true"] .loy-cs-chevron { transform: rotate(180deg); }
    .loy-cs-dropdown {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      min-width: 220px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.13);
      list-style: none;
      margin: 0;
      padding: 6px 0;
      max-height: 300px;
      overflow-y: auto;
      z-index: 99999;
    }
    .loy-cs-option {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 14px;
      cursor: pointer;
      color: #333;
      font-size: 13px;
      transition: background 0.15s;
    }
    .loy-cs-option:hover { background: #f5f5f5; }
    .loy-cs-option--active { background: #f0f0f0; font-weight: 600; }
    .loy-cs-option-flag  { font-size: 18px; line-height: 1; flex-shrink: 0; }
    .loy-cs-option-label { flex: 1; }
  </style>

  <script>
  (function () {
    var DATA_ID   = "loy-cs-data-{{ block.id }}";
    var STORE_KEY = "loy_currency_{{ block.id }}";

    // ── Read data from Liquid-rendered container ──────────────
    var dataEl = document.getElementById(DATA_ID);
    if (!dataEl) return;

    var BASE_CURRENCY  = dataEl.dataset.base        || "INR";
    var MONEY_FORMAT   = dataEl.dataset.moneyFormat || "₹{{amount}}";

    var currencies = [];
    dataEl.querySelectorAll("span[data-country]").forEach(function (s) {
      currencies.push({
        country: s.dataset.country,
        code:    s.dataset.code,
        label:   s.dataset.label,
        flag:    s.dataset.flag,
        symbol:  s.dataset.symbol
      });
    });
    if (!currencies.length) return;

    // ── Exchange rate cache ───────────────────────────────────
    var rates   = null;   // { USD: 0.012, EUR: 0.011, ... }
    var ratesFetched = false;
    var converting = false; // guard against MutationObserver re-entrancy

    function fetchRates(cb) {
      if (rates) { cb(rates); return; }
      fetch("https://open.er-api.com/v6/latest/" + BASE_CURRENCY)
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data && data.rates) {
            rates = data.rates;
            ratesFetched = true;
          }
          cb(rates);
        })
        .catch(function () { cb(null); });
    }

    // ── Format money using Shopify money_format ───────────────
    function formatMoney(amount, toCurrency, symbol) {
      var fmt    = MONEY_FORMAT;
      var val    = parseFloat(amount) || 0;
      var str;

      if (fmt.indexOf("{{amount_no_decimals}}") !== -1) {
        str = Math.round(val).toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        fmt = fmt.replace("{{amount_no_decimals}}", str);
      } else if (fmt.indexOf("{{amount_with_comma_separator}}") !== -1) {
        str = val.toFixed(2).replace(".", ",");
        fmt = fmt.replace("{{amount_with_comma_separator}}", str);
      } else {
        str = val.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
        fmt = fmt.replace("{{amount}}", str);
      }

      // Replace the base currency symbol with the target symbol
      // fmt currently has the base symbol (e.g. ₹); swap it
      if (symbol && symbol !== "") {
        var baseSymbol = MONEY_FORMAT.replace(/\{\{[^}]+\}\}/g, "").trim();
        if (baseSymbol) {
          fmt = fmt.replace(baseSymbol, symbol);
        }
      }
      return fmt;
    }

    // ── Price selectors (covers most Shopify themes) ──────────
    var PRICE_SELECTORS = [
      ".price__regular .price-item",
      ".price__sale .price-item",
      ".price-item",
      ".price__current",
      ".product-price__price",
      ".product__price .price",
      ".cart-item__price",
      ".cart__price",
      ".totals__subtotal-value",
      ".order-summary__emphasis",
      "[data-product-price]",
      "[class*='price__']",
      ".price"
    ].join(",");

    // ── Store original amounts as data attributes ─────────────
    function storeOriginals() {
      document.querySelectorAll(PRICE_SELECTORS).forEach(function (el) {
        if (el.dataset.loyOriginal) return; // already stored
        var text = el.textContent.trim();
        // Extract numeric value: strip currency symbols/spaces, remove thousand-sep commas
        var raw  = text.replace(/[^\d.,]/g, "")   // keep only digits, dot, comma
                       .replace(/,/g, "")          // remove all commas (handles 1,234 and 1,23,456)
                       .replace(/\.(?=.*\.)/g, ""); // remove all but the last dot (edge-case safety)
        var num  = parseFloat(raw);
        if (!isNaN(num) && num > 0) {
          el.dataset.loyOriginal     = num;
          el.dataset.loyOriginalText = text;
        }
      });
    }

    // ── Convert all prices to target currency ─────────────────
    function convertPrices(toCurrency, symbol) {
      if (!rates) return;
      var rate = rates[toCurrency];
      if (!rate) return;

      converting = true;
      document.querySelectorAll(PRICE_SELECTORS).forEach(function (el) {
        if (!el.dataset.loyOriginal) return;
        var original  = parseFloat(el.dataset.loyOriginal);
        var converted = original * rate;
        el.textContent = formatMoney(converted, toCurrency, symbol);
      });
      converting = false;
    }

    // ── Reset prices to base currency ─────────────────────────
    function resetPrices() {
      converting = true;
      document.querySelectorAll(PRICE_SELECTORS).forEach(function (el) {
        if (el.dataset.loyOriginalText) {
          el.textContent = el.dataset.loyOriginalText;
        }
      });
      converting = false;
    }

    // ── Apply a currency (fetch rates if needed) ──────────────
    function applyCurrency(cur) {
      storeOriginals();
      if (cur.code === BASE_CURRENCY) {
        resetPrices();
        return;
      }
      fetchRates(function (r) {
        if (r) convertPrices(cur.code, cur.symbol);
      });
    }

    // ── Build the dropdown widget ─────────────────────────────
    function buildWidget(activeCur) {
      var wrap = document.createElement("div");
      wrap.className = "loy-cs-wrap";

      var trigger = document.createElement("button");
      trigger.type      = "button";
      trigger.className = "loy-cs-trigger";
      trigger.setAttribute("aria-haspopup", "listbox");
      trigger.setAttribute("aria-expanded", "false");
      trigger.innerHTML =
        '<span class="loy-cs-flag">'  + (activeCur.flag  || activeCur.symbol) + '</span>' +
        '<span class="loy-cs-label">' + activeCur.label  + ' (' + activeCur.code + ')</span>' +
        '<span class="loy-cs-chevron"><svg width="10" height="10" viewBox="0 0 10 10" fill="none">' +
          '<path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>' +
        '</svg></span>';

      var list = document.createElement("ul");
      list.className = "loy-cs-dropdown";
      list.setAttribute("role", "listbox");
      list.style.display = "none";

      currencies.forEach(function (c) {
        var isActive = c.code === activeCur.code;
        var li = document.createElement("li");
        li.className = "loy-cs-option" + (isActive ? " loy-cs-option--active" : "");
        li.setAttribute("role", "option");
        li.setAttribute("aria-selected", isActive ? "true" : "false");
        li.dataset.code    = c.code;
        li.dataset.country = c.country;
        li.dataset.symbol  = c.symbol;
        li.dataset.label   = c.label;
        li.dataset.flag    = c.flag || c.symbol;
        li.innerHTML =
          '<span class="loy-cs-option-flag">'  + (c.flag || c.symbol) + '</span>' +
          '<span class="loy-cs-option-label">' + c.label + ' (' + c.code + ')</span>';
        list.appendChild(li);
      });

      wrap.appendChild(trigger);
      wrap.appendChild(list);

      // Toggle open/close
      trigger.addEventListener("click", function (e) {
        e.stopPropagation();
        var open = list.style.display === "block";
        list.style.display = open ? "none" : "block";
        trigger.setAttribute("aria-expanded", open ? "false" : "true");
      });
      document.addEventListener("click", function (e) {
        if (!wrap.contains(e.target)) {
          list.style.display = "none";
          trigger.setAttribute("aria-expanded", "false");
        }
      });

      // Option click — convert prices
      list.querySelectorAll(".loy-cs-option").forEach(function (opt) {
        opt.addEventListener("click", function () {
          var cur = {
            code:   opt.dataset.code,
            symbol: opt.dataset.symbol,
            label:  opt.dataset.label,
            flag:   opt.dataset.flag
          };

          // Update trigger
          trigger.querySelector(".loy-cs-flag").textContent  = cur.flag || cur.symbol;
          trigger.querySelector(".loy-cs-label").textContent = cur.label + " (" + cur.code + ")";

          // Update active state
          list.querySelectorAll(".loy-cs-option").forEach(function (o) {
            o.classList.remove("loy-cs-option--active");
            o.setAttribute("aria-selected", "false");
          });
          opt.classList.add("loy-cs-option--active");
          opt.setAttribute("aria-selected", "true");

          list.style.display = "none";
          trigger.setAttribute("aria-expanded", "false");

          // Save + convert
          localStorage.setItem(STORE_KEY, JSON.stringify(cur));
          applyCurrency(cur);
        });
      });

      return wrap;
    }

    // ── Inject bar below header ───────────────────────────────
    function inject(wrap) {
      var bar = document.createElement("div");
      bar.id = "loy-cs-bar-{{ block.id }}";
      bar.appendChild(wrap);

      // Insert at very top of body — most reliable cross-theme approach
      document.body.insertBefore(bar, document.body.firstChild);
    }

    // ── Init ─────────────────────────────────────────────────
    function init() {
      // Determine active currency (saved or default base)
      var saved      = null;
      var savedRaw   = localStorage.getItem(STORE_KEY);
      try { if (savedRaw) saved = JSON.parse(savedRaw); } catch(e) {}

      var activeCur  = currencies.find(function(c){ return c.code === BASE_CURRENCY; }) || currencies[0];
      if (saved && currencies.find(function(c){ return c.code === saved.code; })) {
        activeCur = saved;
      }

      var wrap = buildWidget(activeCur);
      inject(wrap);

      // Apply saved currency on page load
      if (saved && saved.code !== BASE_CURRENCY) {
        storeOriginals();
        fetchRates(function(r) {
          if (r) convertPrices(saved.code, saved.symbol);
        });
      }

      // Watch for dynamic price changes (variant switches, cart updates)
      if (window.MutationObserver) {
        var observer = new MutationObserver(function () {
          if (converting) return; // skip updates we triggered ourselves
          var cur = null;
          var raw = localStorage.getItem(STORE_KEY);
          try { if (raw) cur = JSON.parse(raw); } catch(e) {}
          if (cur && cur.code !== BASE_CURRENCY) {
            storeOriginals();
            if (rates) convertPrices(cur.code, cur.symbol);
          }
        });
        observer.observe(document.body, { childList: true, subtree: true, characterData: true });
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
  </script>

{% endunless %}

{% schema %}
{
  "name": "Currency Selector",
  "target": "body",
  "settings": [
    {
      "type": "header",
      "content": "Bar"
    },
    {
      "type": "color",
      "id": "bar_background",
      "label": "Bar background color",
      "default": "#f8f8f8"
    },
    {
      "type": "range",
      "id": "bar_padding_x",
      "label": "Bar side padding (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "hover_color",
      "label": "Button hover background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 6
    }
  ]
}
{% endschema %}
