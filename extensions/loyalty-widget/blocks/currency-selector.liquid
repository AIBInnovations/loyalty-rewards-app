{% comment %}
  Currency Selector - App Embed (body target)
  Appears in Theme Editor → App Embeds panel.
  Injects the currency dropdown into the store header automatically.
  Currencies configured from app admin → Currency Selector page.
{% endcomment %}

{% assign cs_enabled = shop.metafields.loyalty_widget.currency_selector_enabled | default: true %}
{% assign custom_currencies = shop.metafields.loyalty_widget.currencies %}

{% unless cs_enabled == false %}

  {% if custom_currencies != blank %}
    {% assign use_custom = true %}
  {% else %}
    {% assign use_custom = false %}
  {% endif %}

  {% comment %} Render hidden data container — JS reads from it {% endcomment %}
  <div id="loy-cs-data-{{ block.id }}" style="display:none;"
    data-current-country="{{ localization.country.iso_code }}"
  >
    {% if use_custom %}
      {% for cur in custom_currencies %}
        <span
          data-country="{{ cur.countryCode }}"
          data-code="{{ cur.currencyCode }}"
          data-label="{{ cur.label | escape }}"
          data-flag="{{ cur.flag }}"
        ></span>
      {% endfor %}
    {% else %}
      {% for country in localization.available_countries %}
        <span
          data-country="{{ country.iso_code }}"
          data-code="{{ country.currency.iso_code }}"
          data-label="{{ country.name | escape }}"
          data-flag="{{ country.currency.symbol }}"
        ></span>
      {% endfor %}
    {% endif %}
  </div>

  {% comment %} Hidden localization form {% endcomment %}
  {% form 'localization', id: 'loy-cs-form-{{ block.id }}' %}
    <select name="country_code" id="loy-cs-native-{{ block.id }}" style="display:none;" aria-hidden="true">
      {% if use_custom %}
        {% for cur in custom_currencies %}
          <option value="{{ cur.countryCode }}"
            {% if cur.countryCode == localization.country.iso_code %}selected{% endif %}
          >{{ cur.currencyCode }}</option>
        {% endfor %}
      {% else %}
        {% for country in localization.available_countries %}
          <option value="{{ country.iso_code }}"
            {% if country.iso_code == localization.country.iso_code %}selected{% endif %}
          >{{ country.currency.iso_code }}</option>
        {% endfor %}
      {% endif %}
    </select>
  {% endform %}

  <style>
    .loy-cs-wrap {
      position: relative;
      display: inline-flex;
      align-items: center;
      font-family: inherit;
      font-size: 13px;
      z-index: 1000;
    }
    .loy-cs-trigger {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: {{ block.settings.background_color }};
      color: {{ block.settings.text_color }};
      border: 1px solid {{ block.settings.border_color }};
      border-radius: {{ block.settings.border_radius }}px;
      padding: 6px 10px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      min-width: 120px;
      text-align: left;
      line-height: 1.4;
      white-space: nowrap;
    }
    .loy-cs-trigger:hover { background: {{ block.settings.hover_color }}; }
    .loy-cs-flag  { font-size: 16px; line-height: 1; flex-shrink: 0; }
    .loy-cs-label { flex: 1; }
    .loy-cs-chevron {
      color: #999;
      flex-shrink: 0;
      transition: transform 0.2s;
      display: flex;
      align-items: center;
    }
    .loy-cs-trigger[aria-expanded="true"] .loy-cs-chevron { transform: rotate(180deg); }
    .loy-cs-dropdown {
      position: absolute;
      top: calc(100% + 4px);
      left: 0;
      min-width: 200px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      list-style: none;
      margin: 0;
      padding: 6px 0;
      max-height: 280px;
      overflow-y: auto;
      z-index: 99999;
    }
    .loy-cs-option {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 14px;
      cursor: pointer;
      color: #333;
      font-size: 13px;
      transition: background 0.15s;
    }
    .loy-cs-option:hover { background: #f5f5f5; }
    .loy-cs-option--active { background: #f0f0f0; font-weight: 600; }
    .loy-cs-option-flag  { font-size: 18px; line-height: 1; flex-shrink: 0; }
    .loy-cs-option-label { flex: 1; }
  </style>

  <script>
  (function () {
    var DATA_ID   = "loy-cs-data-{{ block.id }}";
    var FORM_ID   = "loy-cs-form-{{ block.id }}";
    var NATIVE_ID = "loy-cs-native-{{ block.id }}";

    function buildWidget(currencies, currentCountry) {
      var current = currencies.find(function(c){ return c.country === currentCountry; }) || currencies[0];
      if (!current) return;

      // ── wrapper
      var wrap = document.createElement("div");
      wrap.className = "loy-cs-wrap";
      wrap.id = "loy-cs-wrap-{{ block.id }}";

      // ── trigger button
      var trigger = document.createElement("button");
      trigger.type = "button";
      trigger.className = "loy-cs-trigger";
      trigger.setAttribute("aria-haspopup", "listbox");
      trigger.setAttribute("aria-expanded", "false");
      trigger.innerHTML =
        '<span class="loy-cs-flag">'   + current.flag  + '</span>' +
        '<span class="loy-cs-label">'  + current.label + ' (' + current.code + ')</span>' +
        '<span class="loy-cs-chevron"><svg width="10" height="10" viewBox="0 0 10 10" fill="none">' +
          '<path d="M2 3.5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>' +
        '</svg></span>';

      // ── dropdown
      var list = document.createElement("ul");
      list.className = "loy-cs-dropdown";
      list.setAttribute("role", "listbox");
      list.style.display = "none";

      currencies.forEach(function (c) {
        var li = document.createElement("li");
        li.className = "loy-cs-option" + (c.country === currentCountry ? " loy-cs-option--active" : "");
        li.setAttribute("role", "option");
        li.setAttribute("data-value", c.country);
        li.setAttribute("aria-selected", c.country === currentCountry ? "true" : "false");
        li.innerHTML =
          '<span class="loy-cs-option-flag">'  + c.flag  + '</span>' +
          '<span class="loy-cs-option-label">' + c.label + ' (' + c.code + ')</span>';
        list.appendChild(li);
      });

      wrap.appendChild(trigger);
      wrap.appendChild(list);

      // ── events
      trigger.addEventListener("click", function (e) {
        e.stopPropagation();
        var open = list.style.display === "block";
        list.style.display = open ? "none" : "block";
        trigger.setAttribute("aria-expanded", open ? "false" : "true");
      });

      document.addEventListener("click", function (e) {
        if (!wrap.contains(e.target)) {
          list.style.display = "none";
          trigger.setAttribute("aria-expanded", "false");
        }
      });

      list.querySelectorAll(".loy-cs-option").forEach(function (opt) {
        opt.addEventListener("click", function () {
          var val   = opt.dataset.value;
          var flag  = opt.querySelector(".loy-cs-option-flag").textContent;
          var label = opt.querySelector(".loy-cs-option-label").textContent;

          trigger.querySelector(".loy-cs-flag").textContent  = flag;
          trigger.querySelector(".loy-cs-label").textContent = label;

          list.querySelectorAll(".loy-cs-option").forEach(function(o){
            o.classList.remove("loy-cs-option--active");
            o.setAttribute("aria-selected","false");
          });
          opt.classList.add("loy-cs-option--active");
          opt.setAttribute("aria-selected","true");

          list.style.display = "none";
          trigger.setAttribute("aria-expanded","false");

          var native = document.getElementById(NATIVE_ID);
          var form   = document.getElementById(FORM_ID);
          if (native) native.value = val;
          if (form)   form.submit();
        });
      });

      return wrap;
    }

    function injectWidget(wrap) {
      // Wrap in a full-width bar that sits below the header
      var bar = document.createElement("div");
      bar.id = "loy-cs-bar-{{ block.id }}";
      bar.style.cssText = [
        "width:100%",
        "display:flex",
        "align-items:center",
        "padding:6px {{ block.settings.bar_padding_x }}px",
        "background:{{ block.settings.bar_background }}",
        "border-bottom:1px solid {{ block.settings.border_color }}",
        "box-sizing:border-box",
        "z-index:999",
        "position:relative"
      ].join(";");
      bar.appendChild(wrap);

      // Try to insert after the header element
      var headerSelectors = [
        "header",
        ".header",
        ".site-header",
        "#header",
        ".header-wrapper",
        ".shopify-section-header"
      ];

      var inserted = false;
      for (var i = 0; i < headerSelectors.length; i++) {
        var el = document.querySelector(headerSelectors[i]);
        if (el) {
          el.parentNode.insertBefore(bar, el.nextSibling);
          inserted = true;
          break;
        }
      }

      // Fallback: prepend to main content
      if (!inserted) {
        var main = document.querySelector("main") || document.body;
        main.insertBefore(bar, main.firstChild);
      }
    }

    function init() {
      var dataEl = document.getElementById(DATA_ID);
      if (!dataEl) return;

      var spans = dataEl.querySelectorAll("span[data-country]");
      if (!spans.length) return;

      var currencies = [];
      spans.forEach(function (span) {
        currencies.push({
          country: span.dataset.country,
          code:    span.dataset.code,
          label:   span.dataset.label,
          flag:    span.dataset.flag
        });
      });

      var currentCountry = dataEl.dataset.currentCountry || "";
      var wrap = buildWidget(currencies, currentCountry);
      if (wrap) injectWidget(wrap);
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
  </script>

{% endunless %}

{% schema %}
{
  "name": "Currency Selector",
  "target": "body",
  "settings": [
    {
      "type": "header",
      "content": "Bar"
    },
    {
      "type": "color",
      "id": "bar_background",
      "label": "Bar background color",
      "default": "#f8f8f8"
    },
    {
      "type": "range",
      "id": "bar_padding_x",
      "label": "Bar side padding (px)",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 16
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "hover_color",
      "label": "Button hover background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "default": 6
    }
  ]
}
{% endschema %}
