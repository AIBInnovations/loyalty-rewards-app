{% assign base_currency = shop.currency %}
{% assign money_format = shop.money_format %}

<div id="loy-cs-root"
     data-base="{{ base_currency }}"
     data-fmt="{{ money_format | escape }}"
     style="position:fixed !important;bottom:162px !important;right:20px !important;z-index:9999999 !important;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif !important;">
  <button id="loy-cs-fab" type="button"
          style="display:inline-flex !important;align-items:center !important;gap:6px !important;padding:8px 14px !important;background:#fff !important;border:1.5px solid #ddd !important;border-radius:24px !important;box-shadow:0 2px 10px rgba(0,0,0,.14) !important;cursor:pointer !important;white-space:nowrap !important;font-size:13px !important;font-weight:700 !important;color:#333 !important;outline:none !important;font-family:inherit !important;">
    <span id="loy-cs-label" style="font-size:13px !important;font-weight:700 !important;color:#333 !important;letter-spacing:.4px !important;line-height:1 !important;">{{ base_currency }}</span>
    <svg id="loy-cs-chevron" xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 12 12"
         fill="none" stroke="#666" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"
         style="transition:transform .2s !important;flex-shrink:0 !important;display:inline-block !important;">
      <path d="M2 4l4 4 4-4"/>
    </svg>
  </button>
</div>

<script>
(function () {
  var root    = document.getElementById("loy-cs-root");
  var fab     = document.getElementById("loy-cs-fab");
  var labelEl = document.getElementById("loy-cs-label");
  var chevron = document.getElementById("loy-cs-chevron");
  if (!root || !fab) return;

  var BASE = root.getAttribute("data-base") || "INR";
  var FMT  = root.getAttribute("data-fmt")  || "{{amount}}";
  var dd   = null;

  var FALLBACK = [
    {currencyCode:"INR",symbol:"\u20B9",flag:"\uD83C\uDDEE\uD83C\uDDF3",label:"Indian Rupee"},
    {currencyCode:"USD",symbol:"$",flag:"\uD83C\uDDFA\uD83C\uDDF8",label:"US Dollar"},
    {currencyCode:"GBP",symbol:"\u00A3",flag:"\uD83C\uDDEC\uD83C\uDDE7",label:"British Pound"},
    {currencyCode:"EUR",symbol:"\u20AC",flag:"\uD83C\uDDEA\uD83C\uDDFA",label:"Euro"},
    {currencyCode:"AUD",symbol:"A$",flag:"\uD83C\uDDE6\uD83C\uDDFA",label:"Australian Dollar"},
    {currencyCode:"AED",symbol:"AED",flag:"\uD83C\uDDE6\uD83C\uDDEA",label:"UAE Dirham"},
    {currencyCode:"SAR",symbol:"SAR",flag:"\uD83C\uDDF8\uD83C\uDDE6",label:"Saudi Riyal"},
    {currencyCode:"CAD",symbol:"CA$",flag:"\uD83C\uDDE8\uD83C\uDDE6",label:"Canadian Dollar"},
    {currencyCode:"SGD",symbol:"S$",flag:"\uD83C\uDDF8\uD83C\uDDEC",label:"Singapore Dollar"},
    {currencyCode:"JPY",symbol:"\u00A5",flag:"\uD83C\uDDEF\uD83C\uDDF5",label:"Japanese Yen"}
  ];

  /* ── Attach FAB click listeners once ───────────────────────── */
  fab.addEventListener("click", function (e) {
    e.stopPropagation();
    if (!dd) return;
    dd.style.display === "block" ? closeDD() : openDD();
  });
  document.addEventListener("click", function (e) {
    if (dd && dd.style.display === "block" && !dd.contains(e.target) && !fab.contains(e.target)) closeDD();
  });

  /* ── Build dropdown immediately with fallback so button is always usable ── */
  buildDropdown(FALLBACK);

  /* ── Fetch admin-configured currencies from app proxy (replaces fallback) ── */
  fetch("/apps/loyalty/currency-settings?t=" + Date.now())
    .then(function (r) {
      if (!r.ok) throw new Error("proxy " + r.status);
      var ct = r.headers.get("content-type") || "";
      if (ct.indexOf("application/json") === -1) throw new Error("not json");
      return r.json();
    })
    .then(function (data) {
      if (!data) return;
      if (data.enabled === false) {
        // Admin disabled the selector → hide FAB and remove dropdown
        fab.style.setProperty("display", "none", "important");
        if (dd && dd.parentNode) dd.parentNode.removeChild(dd);
        return;
      }
      var currencies = Array.isArray(data.currencies) ? data.currencies : [];
      if (!currencies.length) return; // keep fallback
      // Replace fallback dropdown with admin-configured one
      if (dd && dd.parentNode) dd.parentNode.removeChild(dd);
      buildDropdown(currencies);
    })
    .catch(function () { /* keep fallback dropdown */ });

  /* ── Build dropdown entirely in JS with inline styles ──────── */
  function buildDropdown(currencies) {
    dd = document.createElement("div");
    dd.style.cssText = "display:none;position:fixed;z-index:10000000;background:#fff;border:1px solid #e0e0e0;border-radius:12px;box-shadow:0 8px 32px rgba(0,0,0,.18);min-width:250px;max-height:320px;overflow-y:auto;overflow-x:hidden;padding:6px 0;margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;";

    currencies.forEach(function (cur) {
      var row = document.createElement("div");
      row.setAttribute("data-code", cur.currencyCode);
      row.style.cssText = "display:flex;align-items:center;gap:10px;padding:10px 16px;cursor:pointer;font-size:13px;color:#333;background:transparent;width:100%;box-sizing:border-box;line-height:1.4;margin:0;";

      var flag = document.createElement("span");
      flag.textContent = cur.flag || "";
      flag.style.cssText = "font-size:20px;line-height:1;flex-shrink:0;display:inline-block;color:#333;";

      var name = document.createElement("span");
      name.textContent = (cur.label || cur.currencyCode) + " (" + cur.currencyCode + ")";
      name.style.cssText = "flex:1;font-size:13px;color:#333;display:inline-block;";

      row.appendChild(flag);
      row.appendChild(name);

      row.addEventListener("mouseenter", function () {
        if (!row._active) row.style.background = "#f5f5f5";
      });
      row.addEventListener("mouseleave", function () {
        row.style.background = row._active ? "#eef2ff" : "transparent";
      });
      row.addEventListener("click", function (e) {
        e.stopPropagation();
        dd.querySelectorAll("[data-code]").forEach(function (r) {
          r.style.background = "transparent"; r.style.fontWeight = "normal"; r._active = false;
        });
        row.style.background = "#eef2ff"; row.style.fontWeight = "600"; row._active = true;
        labelEl.textContent = (cur.flag ? cur.flag + " " : "") + cur.currencyCode;
        closeDD();
        localStorage.setItem("loy_currency", JSON.stringify({
          code: cur.currencyCode, symbol: cur.symbol, flag: cur.flag || "", label: cur.label
        }));
        applyRate(cur.currencyCode, cur.symbol);
      });

      dd.appendChild(row);
    });

    document.body.appendChild(dd);

    /* Restore previously selected currency (if any) */
    try {
      var saved = JSON.parse(localStorage.getItem("loy_currency") || "null");
      if (saved && saved.code && saved.code !== BASE) {
        labelEl.textContent = (saved.flag ? saved.flag + " " : "") + saved.code;
        var selRow = dd.querySelector('[data-code="' + saved.code + '"]');
        if (selRow) { selRow.style.background = "#eef2ff"; selRow.style.fontWeight = "600"; selRow._active = true; }
        storeOrig();
        fetchRates(function (r) { if (r && r[saved.code]) convertPrices(r[saved.code], saved.symbol); });
      }
    } catch (e) {}
  }

  function openDD() {
    var rect  = fab.getBoundingClientRect();
    var rows  = dd.querySelectorAll("[data-code]").length;
    var dropH = Math.min(320, rows * 44 + 12);
    dd.style.right = (window.innerWidth - rect.right) + "px";
    dd.style.left  = "auto";
    if (window.innerHeight - rect.bottom >= dropH + 8) {
      dd.style.top = (rect.bottom + 6) + "px"; dd.style.bottom = "auto";
    } else {
      dd.style.bottom = (window.innerHeight - rect.top + 6) + "px"; dd.style.top = "auto";
    }
    dd.style.display = "block";
    chevron.style.transform = "rotate(180deg)";
  }
  function closeDD() {
    dd.style.display = "none";
    chevron.style.transform = "rotate(0deg)";
  }

  /* ── Price conversion ──────────────────────────────────────── */
  var rates = null, converting = false;
  var SEL = ".price-item,.price-item--regular,.price-item--sale,.price-item--last,.price__current,.product-price__price,.cart-item__price,.cart__price,.totals__subtotal-value,[data-product-price],[data-price]";

  function formatNumber(val) {
    // 1234.56 → "1,234.56"; integer values drop decimals
    if (val >= 1000) return Math.round(val).toLocaleString("en-US");
    return val.toFixed(2);
  }

  function storeOrig() {
    document.querySelectorAll(SEL).forEach(function (el) {
      if (el.dataset.loyOrig) return;
      // Skip elements that contain other price elements (process leaves only)
      if (el.querySelector(SEL)) return;
      var txt = (el.textContent || "").trim();
      if (!txt) return;
      // Extract numeric value — handle formats like "₹1,299.00", "$1.299,00", "1299"
      var cleaned = txt.replace(/[^\d.,]/g, "");
      if (!cleaned) return;
      // If we have both , and . determine which is the decimal separator
      var num;
      if (cleaned.indexOf(",") !== -1 && cleaned.indexOf(".") !== -1) {
        if (cleaned.lastIndexOf(",") > cleaned.lastIndexOf(".")) {
          // European: 1.299,00
          num = parseFloat(cleaned.replace(/\./g, "").replace(",", "."));
        } else {
          // US: 1,299.00
          num = parseFloat(cleaned.replace(/,/g, ""));
        }
      } else {
        num = parseFloat(cleaned.replace(/,/g, ""));
      }
      if (!isNaN(num) && num > 0) {
        el.dataset.loyOrig = num;
        el.dataset.loyOrigTxt = txt;
      }
    });
  }

  function convertPrices(rate, sym) {
    converting = true;
    document.querySelectorAll("[data-loy-orig]").forEach(function (el) {
      var val = parseFloat(el.dataset.loyOrig) * rate;
      el.textContent = (sym || "") + formatNumber(val);
    });
    converting = false;
  }

  function resetPrices() {
    converting = true;
    document.querySelectorAll("[data-loy-orig]").forEach(function (el) {
      if (el.dataset.loyOrigTxt) el.textContent = el.dataset.loyOrigTxt;
    });
    converting = false;
  }
  // External rate API has no guaranteed SLA — cap fetches so a hung request
  // never keeps the browser tab in a "loading" state indefinitely.
  function fetchWithTimeout(url, ms) {
    if (typeof AbortController === "undefined") return fetch(url);
    var ctrl = new AbortController();
    var t = setTimeout(function () { ctrl.abort(); }, ms);
    return fetch(url, { signal: ctrl.signal }).finally(function () { clearTimeout(t); });
  }

  function fetchRates(cb) {
    if (rates) { cb(rates); return; }
    fetchWithTimeout("https://open.er-api.com/v6/latest/" + BASE, 5000)
      .then(function (r) { return r.json(); })
      .then(function (d) { if (d && d.rates) rates = d.rates; cb(rates); })
      .catch(function () { cb(null); });
  }
  function applyRate(c, sym) {
    storeOrig();
    if (c === BASE) { resetPrices(); stopObserver(); return; }
    fetchRates(function (r) {
      if (r && r[c]) { convertPrices(r[c], sym); startObserver(); }
    });
  }

  /* ── MutationObserver for dynamically loaded prices ──────────
     Only runs when a non-base currency is active. Watches childList
     additions (not characterData) so our own textContent writes don't
     re-trigger it. Debounced + processes only newly added subtrees. */
  var mo = null;
  var moTimer = null;
  function startObserver() {
    if (!window.MutationObserver || mo) return;
    mo = new MutationObserver(function (records) {
      if (converting || moTimer) return;
      // Quick check: did any added node potentially contain a price?
      var hasAddedNodes = false;
      for (var i = 0; i < records.length; i++) {
        if (records[i].addedNodes && records[i].addedNodes.length) { hasAddedNodes = true; break; }
      }
      if (!hasAddedNodes) return;
      moTimer = setTimeout(function () {
        moTimer = null;
        var s = null; try { s = JSON.parse(localStorage.getItem("loy_currency")); } catch (e) {}
        if (!s || s.code === BASE) { stopObserver(); return; }
        storeOrig();
        if (rates && rates[s.code]) convertPrices(rates[s.code], s.symbol);
      }, 150);
    });
    mo.observe(document.body, { childList: true, subtree: true });
  }
  function stopObserver() {
    if (moTimer) { clearTimeout(moTimer); moTimer = null; }
    if (mo) { mo.disconnect(); mo = null; }
  }

  // Kick off the observer only if a non-base currency was previously selected.
  try {
    var initSaved = JSON.parse(localStorage.getItem("loy_currency") || "null");
    if (initSaved && initSaved.code && initSaved.code !== BASE) startObserver();
  } catch (e) {}
})();
</script>

{% schema %}
{
  "name": "Currency Selector",
  "target": "body",
  "settings": []
}
{% endschema %}
